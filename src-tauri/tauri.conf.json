{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CloakGuard",
  "version": "0.7.3",
  "identifier": "dev.benthompson.cloakguard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "CloakGuard",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 680,
        "center": true,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --disable-background-networking --disable-component-update --disable-domain-reliability --no-pings"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Utility",
    "publisher": "CloakGuard Project",
    "homepage": "https://github.com/benthompsondev/cloakguard",
    "shortDescription": "Sanitize sensitive text before it leaves your machine.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
