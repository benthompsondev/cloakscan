{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CloakGuard",
  "version": "1.0.1",
  "identifier": "dev.benthompson.cloakguard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "CloakGuard",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 680,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "category": "Utility",
    "publisher": "CloakGuard Project",
    "homepage": "https://github.com/benthompsondev/cloakguard",
    "shortDescription": "Sanitize sensitive text before it leaves your machine.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdGRTkyMjA0OUQ3NTJBQQpSV1NxVXRkSklKTCtCejR1ZWdybXJaanJxODJtSXFTU2NLUW00S1Fram5Wa04yU1VlbzNSaVRqMQo=",
      "endpoints": [
        "https://github.com/benthompsondev/cloakguard/releases/latest/download/latest.json"
      ]
    }
  }
}
