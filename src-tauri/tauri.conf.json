{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CloakScan",
  "version": "1.4.1",
  "identifier": "dev.benthompson.cloakscan",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "CloakScan",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 680,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "category": "Utility",
    "publisher": "CloakScan Project",
    "homepage": "https://github.com/benthompsondev/cloakscan",
    "shortDescription": "Sanitize sensitive text before it leaves your machine.",
    "longDescription": "CloakScan scans pasted text locally for secrets, personal data, infrastructure details, and work-specific terms before sharing. Text is not uploaded, and the app has no account, backend, or telemetry. Automated detection can miss sensitive information, so review the cleaned text before sharing.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdGRTkyMjA0OUQ3NTJBQQpSV1NxVXRkSklKTCtCejR1ZWdybXJaanJxODJtSXFTU2NLUW00S1Fram5Wa04yU1VlbzNSaVRqMQo=",
      "endpoints": [
        "https://github.com/benthompsondev/cloakscan/releases/latest/download/latest.json"
      ]
    }
  }
}
