<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>dev.benthompson.cloakscan</id>
  <name>CloakScan</name>
  <summary>Sanitize sensitive text before sharing it</summary>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <description>
    <p>
      CloakScan scans text locally for secrets, personal data, infrastructure
      details, and work-specific terms before the text is shared.
    </p>
    <p>
      Scanning runs on this device. CloakScan has no account, backend,
      telemetry, or content upload.
    </p>
  </description>
  <launchable type="desktop-id">CloakScan.desktop</launchable>
  <url type="homepage">https://github.com/benthompsondev/cloakscan</url>
  <url type="bugtracker">https://github.com/benthompsondev/cloakscan/issues</url>
  <content_rating type="oars-1.1"/>
  <developer id="dev.benthompson">
    <name>Ben Thompson</name>
  </developer>
  <developer_name>Ben Thompson</developer_name>
  <keywords>
    <keyword>redact</keyword>
    <keyword>sanitize</keyword>
    <keyword>secrets</keyword>
    <keyword>privacy</keyword>
    <keyword>PII</keyword>
  </keywords>
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/benthompsondev/cloakscan/main/docs/screenshots/scan-desktop-1440x900.png</image>
      <caption>Review detected values and the cleaned text before sharing.</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/benthompsondev/cloakscan/main/docs/screenshots/settings-rules-1440x900.png</image>
      <caption>Choose which local detection rules are enabled.</caption>
    </screenshot>
  </screenshots>
  <releases>
    <release version="1.3.0" date="2026-07-10">
      <description>
        <p>
          Adds a Portfolio-code output mode that keeps sanitized PowerShell
          valid, reusable Cloak Lists with JSON import and export, IT
          automation review leads, an invalid-code warning panel, and wider
          test and build validation.
        </p>
      </description>
    </release>
    <release version="1.2.0" date="2026-07-07"/>
